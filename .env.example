# Copy this file to .env and adjust values per device.
# .env is already git-ignored.

# Shared
MODEL_PATH=model.pt
NUM_CLASSES=21
NUM_WORKERS=4

# Training
TRAIN_BATCH_SIZE=32
TRAIN_LEARNING_RATE=0.001
TRAIN_EPOCHS=300

# Validation
VAL_INTERVAL=10
NUM_VAL_SAMPLES=140

# Evaluation
EVAL_BATCH_SIZE=16
EVAL_MAX_EXAMPLES=10
IGNORE_LABEL=255